<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="App6.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:essential="using:WinUI3Package"
    xmlns:local="using:App6"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TitleBar
            Title="Sigewinne"
            Grid.Row="0"
            IsBackButtonVisible="False"
            IsPaneToggleButtonVisible="False"
            Subtitle="Toolkit v6.4b0">

            <TitleBar.LeftHeader>
                <ImageIcon
                    Height="16"
                    Margin="16,0,0,0"
                    Source="/Assets/Logo.ico" />
            </TitleBar.LeftHeader>

            <TitleBar.RightHeader>
                <InfoBar
                    x:Uid="ViewMainAppEdition"
                    IsClosable="False"
                    IsOpen="True"
                    Message=""
                    Severity="Warning" />
            </TitleBar.RightHeader>
        </TitleBar>
        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            AlwaysShowHeader="True"
            Background="Transparent"
            CompactModeThresholdWidth="1000"
            ExpandedModeThresholdWidth="1200"
            IsBackButtonVisible="Auto"
            IsBackEnabled="False"
            IsSettingsVisible="True"
            IsTabStop="False"
            OpenPaneLength="200"
            PaneDisplayMode="Auto"
            SelectionChanged="NavView_SelectionChanged"
            SelectionFollowsFocus="Disabled">
            <NavigationView.Header>
                <TextBlock x:Name="HeaderText" />
            </NavigationView.Header>
            <NavigationView.MenuItems>
                <NavigationViewItem
                    x:Name="SamplePage1Item"
                    x:Uid="ViewMainHome"
                    Tag="SamplePage1">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Play" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

            </NavigationView.MenuItems>
            <NavigationView.Resources />
            <NavigationView.PaneFooter>
                <StackPanel Orientation="Vertical">
                    <NavigationViewItemSeparator />
                    <local:UserView />
                </StackPanel>
            </NavigationView.PaneFooter>

            <Frame x:Name="contentFrame" Padding="10" />
        </NavigationView>
    </Grid>
</UserControl>